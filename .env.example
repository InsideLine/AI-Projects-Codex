AWS_REGION=us-east-1
AWS_PROFILE=
AWS_CLI_PATH=/Users/joeyrogers/Library/Python/3.9/bin/aws

# Preferred production pattern: store Zoho values inside one AWS Secrets Manager JSON secret
# and set only the secret name here.
ZOHO_CREDENTIALS_SECRET_NAME=AxiomProjects/ZohoCRM

# Optional direct local values if you are not using Secrets Manager yet.
ZOHO_DATACENTER=com
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_GRANT_TOKEN=
ZOHO_REDIRECT_URI=http://localhost:8000/zoho/oauth/callback
ZOHO_SCOPES=ZohoCRM.modules.ALL
ZOHO_CRM_API_BASE=

# From prior Zoho Analytics project context.
ZOHO_ANALYTICS_WORKSPACE_NAME=Statistics Pilot
ZOHO_ANALYTICS_WORKSPACE_ID=1738519000007201583
